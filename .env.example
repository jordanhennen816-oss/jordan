# ============================================================
# JARVIS — Примерен .env файл
# Копирайте този файл като .env и попълнете стойностите
# ============================================================

# [ЗАДЪЛЖИТЕЛНО] Anthropic API ключ
# Вземете от: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# [НЕЗАДЪЛЖИТЕЛНО] Имейл конфигурация (за send_email_draft)
# За Gmail: използвайте App Password (не основната парола)
# Вижте: https://support.google.com/accounts/answer/185833
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here
EMAIL_SMTP=smtp.gmail.com
EMAIL_PORT=587
